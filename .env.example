# ─── open context core ───
OPEN_CONTEXT_API_KEY=changeme
OPEN_CONTEXT_PROJECT_UUID=00000000-0000-4000-8000-000000000001

# public url of backend (host machine). sdk appends /api/v2
OPEN_CONTEXT_API_URL=http://localhost:8000

# server-side url inside docker network (used by next.js api routes)
OPEN_CONTEXT_INTERNAL_API_URL=http://backend:8000

# ─── admin ui ───
OPEN_CONTEXT_ADMIN_USERNAME=admin
OPEN_CONTEXT_ADMIN_PASSWORD=admin

# ─── model + graphiti ───
OPENAI_API_KEY=sk-your-key
MODEL_NAME=gpt-4o-mini

# ─── postgres (docker defaults) ───
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=opencontext

# ─── neo4j (docker defaults) ───
# auth is neo4j/zepzepzep in compose

# ─── example fastapi (zep-python reads these) ───
ZEP_API_URL=http://localhost:8000
ZEP_API_KEY=changeme
